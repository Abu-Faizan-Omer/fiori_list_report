<core:FragmentDefinition xmlns="sap.m"
 xmlns:core="sap.ui.core" 
 xmlns:f="sap.ui.layout.form"
 xmlns:u="sap.ui.unified">

    <Dialog contentWidth="60%" title="Upload Photo">
        <Panel headerText="Upload Profile Picture" expandable="true" expanded="true">
            <f:SimpleForm >
                <f:content>
                    <Label text="Select your Photo"></Label>
                    <u:FileUploader id="idFileUploader" uploadUrl="/sap/opu/odata/sap/ZF68FE_EMP_SRV/PhotoSet" sendXHR="true" useMultipart="false"></u:FileUploader>
                    <Label ></Label>
                    <Button width="100px" text="Upload" icon="sap-icon://upload" type="Emphasized" press="uploadPhoto"></Button>
                </f:content>
            </f:SimpleForm>
        </Panel>
        <endButton>
            <Button text="Close" press="onCloseDialog"></Button>
        </endButton>
    </Dialog>

</core:FragmentDefinition>